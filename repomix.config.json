{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "removeComments": false,
    "removeEmptyLines": false,
    "showLineNumbers": true
  },
  "ignore": {
    "customPatterns": [
      "node_modules/**",
      "vendor/**",
      "third_party/**",
      "dist/**",
      "build/**",
      "out/**",
      "target/**",
      "coverage/**",
      ".cache/**",
      ".tmp/**",
      "temp/**",
      ".env",
      ".env.*",
      "*.pem",
      "*.key",
      "*.p12",
      "*.crt",
      "*.log",
      "graphify-out/**",
      ".graphify/**",
      ".ai/generated/graphify/**",
      ".understand-anything/intermediate/**",
      ".understand-anything/diff-overlay.json",
      "repomix-output.*"
    ]
  }
}
